non-fluents cart_pole_disc_v2 {
    domain = cart_pole_discrete_v2;
}

instance inst_cart_pole_disc_v2 {

	domain = cart_pole_discrete_v2;

	non-fluents = cart_pole_disc_v2;

	init-state {
	    pos = 0.0;
        vel = 0.0;
        ang-pos = 0.1;
        ang-vel = 0.0;
	};

	max-nondef-actions = pos-inf;
	horizon  = 200;
	discount = 1.0;
}
